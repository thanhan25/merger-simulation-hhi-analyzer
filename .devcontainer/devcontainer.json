{
  "name": "Merger Simulation Environment",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.13-bullseye",
  "features": {
    "ghcr.io/astral-sh/devcontainers-features/uv:1": {}
  },
  "postCreateCommand": "uv sync --all-extras",
  "postAttachCommand": "uv run merger-sim ui",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "charliermarsh.ruff"
      ]
    }
  },
  "portsAttributes": {
    "8501": {
      "label": "Streamlit Dashboard",
      "onAutoForward": "openBrowser"
    }
  }
}
